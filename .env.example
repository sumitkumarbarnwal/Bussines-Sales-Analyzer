# Flask Environment
FLASK_ENV=production
FLASK_APP=app.py

# Security
SECRET_KEY=change-me-to-a-secure-random-key

# Groq API Key (Required for AI analysis features)
# Get it from https://console.groq.com/keys
GROQ_API_KEY=gsk-your-api-key-here

# Database (if needed)
# DATABASE_URL=sqlite:///database.db
